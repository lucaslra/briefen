# Briefen — environment variable reference
# Copy to .env and adjust for your local setup. All variables have defaults;
# the app starts without this file (defaults are tuned for `make dev`).

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/briefen

# Ollama service URL
OLLAMA_BASE_URL=http://localhost:11434

# Default Ollama model (must be pulled; see docker-compose.yml for available models)
OLLAMA_MODEL=gemma3:4b

# Spring Boot HTTP port
SERVER_PORT=8080
