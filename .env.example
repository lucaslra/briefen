# Briefen — environment variable reference
# Copy to .env and adjust for your setup. All variables have built-in defaults;
# the app starts without this file (defaults are tuned for `make dev` / local Ollama).
#
# Docker users: pass these as environment: entries in docker-compose.yml instead.
# See docker-compose.sample.yml for a production-ready example with comments.

# ── Database ────────────────────────────────────────────────────────────────

# Database engine to use: "sqlite" (default) or "postgres".
# SQLite is zero-config and recommended for most deployments.
# PostgreSQL is available for larger-scale or multi-instance setups.
# Default: sqlite
# BRIEFEN_DB_TYPE=sqlite

# Path to the SQLite database file (only used when BRIEFEN_DB_TYPE=sqlite).
# For Docker, use a path inside a mounted volume (e.g. /data/briefen.db).
# Default: ./data/briefen.db
BRIEFEN_DB_PATH=./data/briefen.db

# PostgreSQL connection settings (required when BRIEFEN_DB_TYPE=postgres).
# All three must be set when using PostgreSQL; the app will fail to start if any is missing.
# BRIEFEN_DATASOURCE_URL=jdbc:postgresql://localhost:5432/briefen
# BRIEFEN_DATASOURCE_USERNAME=briefen
# BRIEFEN_DATASOURCE_PASSWORD=changeme

# ── Server ──────────────────────────────────────────────────────────────────

# HTTP port the app listens on.
# Default: 8080
SERVER_PORT=8080

# Network interface the app binds to.
# Set to 127.0.0.1 to accept connections only from localhost (useful when a
# reverse proxy runs on the same host and you don't want the app accessible
# directly from the network).
# Default: 0.0.0.0 (all interfaces)
SERVER_BIND_ADDRESS=0.0.0.0

# Serve the app at a URL sub-path, e.g. /briefen/ for myserver.com/briefen/.
# Must end with a slash. Also pass the matching --build-arg APP_BASE_PATH=/briefen/
# when building the Docker image locally so Vite bakes the correct asset paths.
# Leave unset (or /) for root deployment (default, and the pre-built GHCR image).
# Default: /
# SERVER_CONTEXT_PATH=/briefen/

# How Spring Boot handles X-Forwarded-* headers from a reverse proxy.
# Set to FRAMEWORK when running behind Nginx, Caddy, or Traefik so that
# redirect URLs and scheme detection work correctly.
# Values: NONE (default, direct access) | FRAMEWORK (behind a reverse proxy)
SERVER_FORWARD_HEADERS_STRATEGY=NONE

# ── CORS ────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins.
# Required when a browser extension or a custom frontend runs on a different
# origin than the backend. Use moz-extension://* for Firefox, chrome-extension://* for Chrome.
# Example: BRIEFEN_CORS_ALLOWED_ORIGINS=moz-extension://*,chrome-extension://*,http://localhost:5173
# Default: (empty — CORS disabled)
BRIEFEN_CORS_ALLOWED_ORIGINS=

# ── Ollama (local LLM) ───────────────────────────────────────────────────────

# URL of the Ollama API server.
# For Docker Compose setups where Ollama is a separate service, use the service
# name: http://ollama:11434. For Ollama running on the host from inside Docker,
# use http://host.docker.internal:11434 (Mac/Windows) or the host's IP (Linux).
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# Default Ollama model to use for summarization.
# The model must already be pulled (e.g. `ollama pull gemma3:4b`).
# Users can override the model per-request in the UI.
# Default: gemma3:4b
OLLAMA_MODEL=gemma3:4b

# ── Cloud LLM providers ──────────────────────────────────────────────────────

# OpenAI API key. When set on first startup, Briefen seeds this into the admin
# user's settings so cloud models are available immediately without logging in
# to configure them. Does not overwrite a key already saved in the database.
# Can also be set later via the Settings page in the browser.
# Default: (empty — OpenAI disabled)
BRIEFEN_OPENAI_API_KEY=

# Anthropic API key. Same seeding behaviour as BRIEFEN_OPENAI_API_KEY above.
# Default: (empty — Anthropic/Claude disabled)
BRIEFEN_ANTHROPIC_API_KEY=

# ── Webhooks ─────────────────────────────────────────────────────────────────

# URL to receive a POST notification whenever a summary is saved.
# Useful for integrations with Home Assistant, n8n, Zapier, etc.
# The payload is JSON: { event, id, url, title, model, createdAt }
# Delivery is fire-and-forget (failures are logged, never retried).
# Default: (empty — webhooks disabled)
BRIEFEN_WEBHOOK_URL=

# ── Logging ───────────────────────────────────────────────────────────────────

# Log verbosity for Briefen's own code (does not affect Spring Boot internals).
# Increase to DEBUG when troubleshooting summarization or Ollama connectivity.
# Values: ERROR | WARN | INFO | DEBUG | TRACE
# Default: INFO
BRIEFEN_LOG_LEVEL=INFO

# Log output format. Set to "json" for structured JSON logs (one JSON object
# per line), useful for log aggregation tools like Loki, Grafana, or jq.
# Any other value (or unset) uses human-readable console output.
# Values: json | (unset for human-readable)
# Default: (unset — human-readable)
# BRIEFEN_LOG_FORMAT=json

# ── Summarization ─────────────────────────────────────────────────────────────

# Custom default system prompt for summarization. When set, this replaces the
# built-in summarization prompt for all users who have not configured a personal
# custom prompt in Settings. Useful for deployment-wide language or style defaults.
# Leave unset to use the built-in English prompt.
# Default: (unset — built-in prompt)
# BRIEFEN_DEFAULT_PROMPT=
